# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings → API → service_role key (NOT anon key — backend needs full access)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── AiSensy ───────────────────────────────────────────────────────────────────
# AiSensy Dashboard → Settings → API Keys → copy the API Key
AISENSY_API_KEY=your_aisensy_api_key_here

# Webhook secret — set this in AiSensy Dashboard → Settings → Webhook → Header Token
# Your backend verifies it on every inbound webhook at POST /webhook/aisensy
AISENSY_WEBHOOK_SECRET=your_webhook_secret_here

# (Optional) If your AiSensy plan requires a pre-approved campaign for sending
# plain-text session messages, set the campaign name here.
# Leave blank if your plan supports the direct message API.
AISENSY_TEXT_CAMPAIGN_NAME=

# (Optional) Campaign name to use for image messages (if direct API not available)
AISENSY_IMAGE_CAMPAIGN_NAME=

# (Optional) Campaign name to use for the auto-reply on first contact
AISENSY_AUTOREPLY_CAMPAIGN=

# ── Meta App (Lead Ads only — WhatsApp messages now go through AiSensy) ────────
# developers.facebook.com → Your App → Settings → Basic → App Secret
META_APP_SECRET=your_meta_app_secret_here
# Token you set when creating the webhook subscription in Meta App Dashboard
META_WEBHOOK_VERIFY_TOKEN=skyhost_webhook_secret_2024
